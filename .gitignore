# --- [1] Data Protection ---
# Strictly ignore all files under data/, preserving only the directory structure
data/*
!data/.gitkeep

# --- [2] Artifacts & Results (Whitelist Approach) ---
# Ignore all generated backtest artifacts under results/
results/*
# Whitelist specific subdirectories, PNG plots, and gitkeep files
!results/**/
!results/**/*.png
!results/**/.gitkeep
# Intercept all runtime log files
*.log

# --- [3] Python & System ---
__pycache__/
*.py[cod]
.venv/
venv/
.vscode/
.idea/
.DS_Store
*.pdf
.ipynb_checkpoints/