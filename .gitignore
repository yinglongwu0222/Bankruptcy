# --- [1] Data & Artifact Protection (Strict Policy) ---
# Never upload raw datasets to prevent leaks or GitHub file size limits
data/*.csv
data/*.xlsx
data/*.zip
data/*.parquet

# Ignore all generated plots and metrics but keep directory structure
results/**/*
!results/**/.gitkeep

# Ignore PDF reports (Distribute via Releases or external links)
*.pdf

# --- [2] Python Environment & Cache ---
__pycache__/
**/*.py[cod]
**/*$py.class
.ipynb_checkpoints/

# Virtual environments
venv/
env/
.env
.venv/
build/
dist/
*.egg-info/

# --- [3] Logging & Debugging ---
*.log
logs/
.pytest_cache/
.coverage
htmlcov/

# --- [4] IDE & System Artifacts (Full Path Protection) ---
.vscode/
.idea/
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db