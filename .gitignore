# --- [1] Data Protection ---
# Prevents accidentally adding new massive datasets
data/*.csv
data/*.xlsx
data/*.zip
# Keep the directory structure
!data/.gitkeep

# --- [2] Artifacts & Results ---
# This matches your current GitHub state: folders exist and images are tracked
!results/**/.gitkeep
!results/**/*.png

# --- [3] Python & System ---
__pycache__/
*.py[cod]
.venv/
venv/
.vscode/
.idea/
.DS_Store
*.pdf