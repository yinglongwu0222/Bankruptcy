# --- [1] Data Protection ---
# Keep the directory but ignore raw big data (following industry best practices)
data/*.csv
data/*.xlsx
data/*.zip
!data/.gitkeep

# --- [2] Artifacts & Results ---
# We explicitly track performance plots for portfolio display
!results/**/*.png
!results/**/.gitkeep

# --- [3] Python Environment & System ---
__pycache__/
*.py[cod]
.venv/
venv/
.env
.vscode/
.idea/
.DS_Store
*.pdf